# status-led credentials. Copy to ~/.status-led/secrets.env and edit:
#   cp secrets.env.example ~/.status-led/secrets.env
#
# Format: KEY=VALUE per line; comments start with '#'; matching surrounding
# quotes are stripped ("key" / 'key' → key). Each integration reads only
# its own prefix — gitlab cannot see SLACK_TOKEN, etc.
#
# The CLI loads ~/.status-led/secrets.env on every dispatch and exposes
# only the matching keys to the subprocess. Integrations never see keys
# outside their prefix.

# GitLab poller (integrations/gitlab/) — prefix GITLAB_
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=replace-me-with-personal-access-token
GITLAB_PROJECTS=myteam/backend,myteam/frontend
