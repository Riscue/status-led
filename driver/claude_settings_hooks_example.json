{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py idle --quiet" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py thinking --quiet" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py tool --quiet" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py thinking --quiet" }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py error --quiet" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py waiting --quiet" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py success --quiet" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_LED_PROJECT_FOLDER/driver/led_driver.py off --quiet" }
        ]
      }
    ]
  }
}
