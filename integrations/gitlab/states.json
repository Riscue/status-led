{
  "_comment": "GitLab pipeline state → animation. Edit freely; install.sh mirrors this folder to ~/.status-led/integrations/gitlab/.",
  "pending": {
    "animation": "breathe",
    "rgb": [200, 200, 200],
    "period": 2000,
    "brightness": 60,
    "priority": 80
  },
  "running": {
    "animation": "scanner",
    "rgb": [0, 100, 200],
    "period": 1500,
    "brightness": 100,
    "priority": 80
  },
  "success": {
    "animation": "fill",
    "rgb": [0, 220, 0],
    "period": 3000,
    "brightness": 100,
    "priority": 80
  },
  "failed": {
    "animation": "blink",
    "rgb": [220, 0, 0],
    "period": 300,
    "brightness": 100,
    "priority": 90
  },
  "canceled": {
    "animation": "off"
  }
}
