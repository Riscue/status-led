{
  "_comment": "GitLab pipeline state → animation. Edit freely; install.sh mirrors this folder to ~/.status-led/integrations/gitlab/.",
  "pending": {
    "animation": "pulse",
    "rgb": [200, 200, 200],
    "period": 1500,
    "brightness": 60,
    "priority": 40
  },
  "running": {
    "animation": "bounce",
    "rgb": [0, 100, 200],
    "period": 1500,
    "brightness": 100,
    "priority": 50
  },
  "success": {
    "animation": "sparkle",
    "rgb": [0, 220, 0],
    "period": 1200,
    "brightness": 100,
    "priority": 20
  },
  "failed": {
    "animation": "blink",
    "rgb": [220, 0, 0],
    "period": 300,
    "brightness": 100,
    "priority": 90
  },
  "canceled": {
    "animation": "off"
  }
}
